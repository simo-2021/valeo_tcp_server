# Nouveau Makefile pour Buildroot
# 29DEC2025 - Arnaud Simo
# Adapt: 04.02.2026


TARGET = writer
SRC = writer.c

# Buildroot fournit CC via l'environnement
CC := aarch64-buildroot-linux-gnu-gcc

CFLAGS += -Wall -Werror
LDFLAGS +=

all: $(TARGET)

$(TARGET): $(SRC)
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $<

clean:
	rm -f $(TARGET) *.o
